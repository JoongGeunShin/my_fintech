# ──────────────────────────────────────────────────────────────────
# KIS (한국투자증권) Open API 설정
# https://apiportal.koreainvestment.com 에서 발급
# ──────────────────────────────────────────────────────────────────
KIS_ACCOUNT_ID=
KIS_ACCOUNT_NUMBER=
KIS_API_APP_KEY=
KIS_API_APP_SECRET_KEY=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# 실전 모드 활성화 비밀번호 (본인만 아는 값으로 설정)
REAL_MODE_SECRET=

# ──────────────────────────────────────────────────────────────────
# Firebase Admin SDK 설정
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# privateKey 개행은 \n 으로 표현 (따옴표로 감쌀 것)
FIREBASE_PRIVATE_KEY=""

# ──────────────────────────────────────────────────────────────────
# 퀀트 지표 파라미터 (직접 설계 및 백테스트 후 설정)
# ──────────────────────────────────────────────────────────────────

# 호가 벽 감지: 평균 잔량 대비 N배 이상이면 벽으로 판정
QUANT_WALL_MULTIPLIER=

# 최소 분봉 평균 거래량 (이 미만이면 저유동성으로 진입 차단)
QUANT_MIN_MINUTE_VOLUME=

# 매수/매도 신호 점수 임계값 (0 ~ 1 범위)
QUANT_BUY_SCORE_THRESHOLD=
QUANT_SELL_SCORE_THRESHOLD=

# BOR(매도/매수 잔량 비율) 임계값
QUANT_BUY_BOR_MAX=
QUANT_SELL_BOR_MIN=

# 체결강도 매수 최소 기준 (%)
QUANT_ES_BUY_MIN=

# 종합 점수 가중치 (합계 = 1.0 이 되도록 설계)
QUANT_WEIGHT_BOR=
QUANT_WEIGHT_TIS=
QUANT_WEIGHT_CVD=
QUANT_WEIGHT_VWAP=
QUANT_WEIGHT_ES=
QUANT_WEIGHT_JUPO=

# ──────────────────────────────────────────────────────────────────
# 리스크 관리 파라미터 (충분한 백테스트 후 설정)
# ──────────────────────────────────────────────────────────────────

# 손절 기준 (음수, 예: -0.03 → -3%)
TRADE_STOP_LOSS_RATE=

# 1차 익절 기준 (양수, 예: 0.02 → +2%)
TRADE_TAKE_PROFIT_RATE=

# 고수익 익절 기준
TRADE_ENHANCED_PROFIT_RATE=

# 주포 따라가기 빠른 익절 기준
TRADE_JUPO_QUICK_PROFIT=

# 계좌 잔고 대비 최대 위험 비율 (예: 0.05 → 5%)
TRADE_RISK_PER_TRADE=

# 단일 포지션 최대 비율 (예: 0.5 → 50%)
TRADE_MAX_POSITION_RATE=

# 일간 손실 한도 (음수, 이 이하면 자동매매 중단)
TRADE_DAILY_LOSS_LIMIT=

# 최소 거래량 비율 (현재 분봉 / 평균 분봉)
TRADE_MIN_VRATE_TO_BUY=

# ──────────────────────────────────────────────────────────────────
# 조건검색 가중치 (eFriend Expert에서 설정한 조건 구조와 맞춰 설정)
# ──────────────────────────────────────────────────────────────────

# Firestore 그룹명 (본인 조건 그룹명과 일치시킬 것)
SCREENING_MAIN_GROUP=my_fintech

# 조건 카테고리별 가중치 ([필수] > [보조] > [세부] 순서로 설계)
SCREENING_WEIGHT_REQUIRED=
SCREENING_WEIGHT_SUPPORT=
SCREENING_WEIGHT_DETAIL=
